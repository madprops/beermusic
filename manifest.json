{
  "manifest_version": 3,
  "name": "Beermusic",
  "version": "1.0",
  "description": "Point and click to capture high-res, upscaled screenshots of specific DOM elements.",
  "permissions": [
    "activeTab",
    "downloads"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "icons": {
    "512": "icon_512.png"
  },
  "action": {
    "default_icon": {
      "512": "icon_512.png"
    },
    "default_title": "Beermusic"
  }
}